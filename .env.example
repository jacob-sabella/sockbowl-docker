# Centralized host configuration
# Change this to your domain/IP for production deployments
APP_HOST=localhost

# Protocol settings
# For production with HTTPS, change to:
# APP_PROTOCOL=https
# WS_PROTOCOL=wss
APP_PROTOCOL=http
WS_PROTOCOL=ws

# Port configuration (for reference, services use host networking)
KEYCLOAK_PORT=8080
SOCKBOWL_GAME_PORT=7000
SOCKBOWL_QUESTIONS_PORT=7009
POSTGRES_PORT=5432
NEO4J_PORT=7687
KAFKA_PORT=9092
REDIS_PORT=6379

# Database credentials
POSTGRES_USER=postgres
POSTGRES_PASSWORD=123456789
NEO4J_USER=neo4j
NEO4J_PASSWORD=123456789

# Keycloak configuration
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin123
KEYCLOAK_ISSUER_URI=http://localhost:8080/realms/sockbowl

# Shared secret the sockbowl-game backend uses for its confidential Keycloak client
# (used by scripts/load-rbac.sh when upserting the RBAC model)
SOCKBOWL_GAME_BACKEND_SECRET=change-me-game-backend-secret

# Authentication
# Two modes:
#   AUTH_ENABLED=false  -> guest mode, zero auth setup
#   AUTH_ENABLED=true   -> Keycloak-backed login + RBAC (roles, ownership, bans) (default,
#                          out-of-the-box authenticated test)
# With the defaults below (AUTH_ENABLED=true, CREATE_DEMO_ACCOUNTS=true), the RBAC loader
# assigns demo user `moderator` the `admin` composite role, so signing in as
# `moderator / demo123` exercises the admin/ban features immediately. Other demo users
# (player1/player2/player3/testuser) get the realm-default `player` role.
# The sockbowl-game client is a public OIDC client, so KEYCLOAK_CLIENT_SECRET stays empty.
AUTH_ENABLED=true
KEYCLOAK_CLIENT_SECRET=

# Keycloak realm admin user (created during realm import)
KEYCLOAK_USER_USERNAME=admin
KEYCLOAK_USER_EMAIL=admin@sockbowl.com
KEYCLOAK_USER_FIRSTNAME=Admin
KEYCLOAK_USER_LASTNAME=User
KEYCLOAK_USER_PASSWORD=admin123

# Demo accounts
# Set to true to create demo accounts for testing
CREATE_DEMO_ACCOUNTS=true

# Sockbowl Game Service Configuration
SOCKBOWL_DATABASE=0
SOCKBOWL_KAFKA_GAME_TOPIC=game-session-topic
SOCKBOWL_GAME_ALLOWED_ORIGINS=http://localhost,http://localhost:80

# Sockbowl Questions Service Configuration
# AI provider for question generation: "openai" or "ollama" (local). Leave chat flags
# false to run without AI (manual packet authoring still works).
SOCKBOWL_AI_PROVIDER=ollama
SOCKBOWL_AI_LOCAL_MODEL=gpt-oss:latest
OPENAI_API_KEY=
SPRING_AI_OPENAI_CHAT_ENABLED=false
SPRING_AI_OLLAMA_CHAT_ENABLED=false
SPRING_AI_OLLAMA_BASE_URL=http://localhost:11434
SPRING_AI_OLLAMA_CHAT_OPTIONS_MODEL=gpt-oss:latest
SOCKBOWL_QUESTIONS_ALLOWED_ORIGINS=http://localhost,http://localhost:80,http://localhost:7000
