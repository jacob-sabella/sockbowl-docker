# Centralized host configuration
# Change this to your domain/IP for production deployments
APP_HOST=localhost

# Protocol settings
# For production with HTTPS, change to:
# APP_PROTOCOL=https
# WS_PROTOCOL=wss
APP_PROTOCOL=http
WS_PROTOCOL=ws

# Port configuration (for reference, services use host networking)
KEYCLOAK_PORT=8080
SOCKBOWL_GAME_PORT=7000
SOCKBOWL_QUESTIONS_PORT=7009
POSTGRES_PORT=5432
NEO4J_PORT=7687
KAFKA_PORT=9092
REDIS_PORT=6379

# Database credentials
POSTGRES_USER=postgres
POSTGRES_PASSWORD=123456789
NEO4J_USER=neo4j
NEO4J_PASSWORD=123456789

# Keycloak configuration
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin123
KEYCLOAK_REALM=sockbowl
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_ISSUER_URI=http://localhost:8080/realms/sockbowl

# Authentication
# Set to true to enable Keycloak authentication
AUTH_ENABLED=false
KEYCLOAK_CLIENT_SECRET=

# Keycloak realm admin user (created during realm import)
KEYCLOAK_USER_USERNAME=admin
KEYCLOAK_USER_EMAIL=admin@sockbowl.com
KEYCLOAK_USER_FIRSTNAME=Admin
KEYCLOAK_USER_LASTNAME=User
KEYCLOAK_USER_PASSWORD=admin123

# Demo accounts
# Set to true to create demo accounts for testing
CREATE_DEMO_ACCOUNTS=false

# Sockbowl Game Service Configuration
SOCKBOWL_DATABASE=0
SOCKBOWL_KAFKA_GAME_TOPIC=game-session-topic
SOCKBOWL_GAME_ALLOWED_ORIGINS=http://localhost,http://localhost:80

# Sockbowl Questions Service Configuration
SOCKBOWL_AI_LOCAL_MODEL=gpt-oss:latest
OPENAI_API_KEY=
SOCKBOWL_QUESTIONS_ALLOWED_ORIGINS=http://localhost,http://localhost:80,http://localhost:7000
