    "admin":     ["author", "moderator", "packet:delete", "admin:access", "packet:manage-any"],
    "user":      ["player"]
  },
  "defaultRole": "player",
  "serviceClient": { "clientId": "sockbowl-game-backend", "roles": ["packet:read"] },
  "demoUserRoles": {
    "testuser": "author",
    "moderator": "moderator",
    "player1": "admin"
  }
